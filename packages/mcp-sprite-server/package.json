{
  "name": "@glyphstudio/mcp-sprite-server",
  "version": "1.0.0",
  "description": "MCP server exposing GlyphStudio sprite editor as 75 programmable tools",
  "type": "module",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "publishConfig": {
    "main": "dist/index.js",
    "types": "dist/index.d.ts",
    "exports": {
      ".": {
        "import": "./dist/index.js",
        "types": "./dist/index.d.ts"
      }
    },
    "bin": {
      "glyphstudio-mcp": "dist/cli.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "prepublishOnly": "pnpm run build"
  },
  "engines": {
    "node": ">=20"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/mcp-tool-shop-org/glyphstudio.git",
    "directory": "packages/mcp-sprite-server"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "sprite",
    "pixel-art",
    "glyphstudio",
    "ai-tools"
  ],
  "license": "MIT",
  "author": "mcp-tool-shop",
  "dependencies": {
    "@glyphstudio/domain": "workspace:*",
    "@glyphstudio/state": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "fast-png": "^8.0.0",
    "zod": "^3.24.0",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "typescript": "^5.7.3",
    "vitest": "^4.1.0"
  }
}
