{
  "name": "@glyphstudio/api-contract",
  "version": "1.0.0",
  "description": "Tauri IPC contract types for GlyphStudio sprite editor",
  "type": "module",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "publishConfig": {
    "main": "dist/index.js",
    "types": "dist/index.d.ts",
    "exports": {
      ".": {
        "import": "./dist/index.js",
        "types": "./dist/index.d.ts"
      }
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "test": "echo \"no tests yet\"",
    "prepublishOnly": "pnpm run build"
  },
  "engines": {
    "node": ">=20"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/mcp-tool-shop-org/glyphstudio.git",
    "directory": "packages/api-contract"
  },
  "license": "MIT",
  "author": "mcp-tool-shop",
  "dependencies": {
    "@glyphstudio/domain": "workspace:*"
  },
  "devDependencies": {
    "typescript": "^5.7.3"
  }
}
